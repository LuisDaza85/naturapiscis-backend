{
  "name": "naturapiscis-backend",
  "version": "1.0.0",
  "description": "Backend API para NaturaPiscis - Plataforma de comercialización de productos acuícolas con IoT integrado",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "dev:debug": "nodemon --inspect src/server.js",
    "test": "jest --coverage --verbose",
    "test:watch": "jest --watch",
    "test:unit": "jest tests/unit --coverage",
    "test:integration": "jest tests/integration --coverage",
    "test:e2e": "jest tests/e2e --coverage",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\"",
    "db:migrate": "node src/database/migrations/run-migrations.js",
    "db:seed": "node src/database/seeds/run-seeds.js",
    "db:reset": "npm run db:migrate && npm run db:seed",
    "logs:clear": "rm -rf logs/*.log",
    "clean": "rm -rf node_modules package-lock.json && npm install",
    "prepare": "husky install || true"
  },
  "keywords": [
    "api",
    "backend",
    "nodejs",
    "express",
    "postgresql",
    "acuicultura",
    "ecommerce",
    "iot",
    "rest-api",
    "jwt",
    "authentication"
  ],
  "author": {
    "name": "NaturaPiscis Team",
    "email": "dev@naturapiscis.com",
    "url": "https://naturapiscis.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/naturapiscis/backend.git"
  },
  "bugs": {
    "url": "https://github.com/naturapiscis/backend/issues"
  },
  "homepage": "https://github.com/naturapiscis/backend#readme",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.6",
    "dotenv": "^16.3.1",
    "expo-server-sdk": "^6.1.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.11.3",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "eslint": "^8.56.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jest": "^27.6.0",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.1",
    "supertest": "^6.3.3"
  },
  "nodemonConfig": {
    "watch": [
      "src/**/*.js",
      ".env"
    ],
    "ignore": [
      "node_modules/**",
      "tests/**",
      "logs/**",
      "uploads/**"
    ],
    "ext": "js,json",
    "exec": "node src/server.js",
    "env": {
      "NODE_ENV": "development"
    }
  },
  "jest": {
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
      "/node_modules/"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/server.js",
      "!src/database/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 70,
        "lines": 70,
        "statements": 70
      }
    }
  },
  "prettier": {
    "semi": true,
    "trailingComma": "es5",
    "singleQuote": true,
    "printWidth": 100,
    "tabWidth": 2,
    "useTabs": false,
    "arrowParens": "always",
    "endOfLine": "lf"
  },
  "eslintConfig": {
    "env": {
      "node": true,
      "es2021": true,
      "jest": true
    },
    "extends": [
      "airbnb-base",
      "prettier"
    ],
    "parserOptions": {
      "ecmaVersion": "latest",
      "sourceType": "module"
    },
    "rules": {
      "no-console": "off",
      "no-underscore-dangle": "off",
      "consistent-return": "off",
      "no-param-reassign": [
        "error",
        {
          "props": false
        }
      ]
    }
  }
}
